# ---------------------------------------------------------------------------
# laravel-mcp-auth — example .env for an Auth0 / Keycloak-style JWKS IdP
# ---------------------------------------------------------------------------
# Copy the relevant lines into your application's .env. These map 1:1 to the
# env() reads in config/mcp-auth.php. See that file for full documentation of
# every option.

# --- Canonical resource identifier (RFC 8707 / RFC 9728) --------------------
# The public URL of THIS MCP server. It is advertised in the Protected Resource
# Metadata document and is the audience every access token MUST be bound to.
# Must EXACTLY match the `resource` your IdP issues tokens for. Leave unset to
# derive it from the request URL (only safe behind a correctly-configured proxy).
MCP_AUTH_RESOURCE=https://api.example.com/mcp/weather
MCP_AUTH_RESOURCE_NAME="Weather MCP Server"

# --- Authorization server (your external IdP issuer) ------------------------
# The OAuth 2.1 issuer URL. Advertised in the metadata document so MCP clients
# can discover where to obtain a token.
#
# Auth0:    https://YOUR_TENANT.us.auth0.com/
# Keycloak: https://keycloak.example.com/realms/YOUR_REALM
MCP_AUTH_AUTHORIZATION_SERVER=https://your-tenant.us.auth0.com/

# --- Token validation strategy ---------------------------------------------
# "jwt"           validate self-contained JWTs locally against the IdP's JWKS.
# "introspection" validate opaque tokens via the IdP's RFC 7662 endpoint.
MCP_AUTH_STRATEGY=jwt

# --- JWT strategy (RFC 9068, validated against JWKS) ------------------------
# JWKS endpoint — keys rotate automatically and are cached (jwks_cache_ttl).
#
# Auth0:    https://YOUR_TENANT.us.auth0.com/.well-known/jwks.json
# Keycloak: https://keycloak.example.com/realms/YOUR_REALM/protocol/openid-connect/certs
MCP_AUTH_JWKS_URI=https://your-tenant.us.auth0.com/.well-known/jwks.json

# Expected token issuer (the `iss` claim). Strongly recommended. Must include
# the trailing slash for Auth0; must be the realm URL for Keycloak.
#
# Auth0:    https://YOUR_TENANT.us.auth0.com/
# Keycloak: https://keycloak.example.com/realms/YOUR_REALM
MCP_AUTH_ISSUER=https://your-tenant.us.auth0.com/

# Optional: a static PEM public key instead of a JWKS endpoint (rarely needed).
# MCP_AUTH_PUBLIC_KEY=

# --- Introspection strategy (RFC 7662) — only when MCP_AUTH_STRATEGY=introspection
# MCP_AUTH_INTROSPECTION_ENDPOINT=https://keycloak.example.com/realms/YOUR_REALM/protocol/openid-connect/token/introspect
# MCP_AUTH_INTROSPECTION_CLIENT_ID=mcp-weather-resource-server
# MCP_AUTH_INTROSPECTION_CLIENT_SECRET=change-me
